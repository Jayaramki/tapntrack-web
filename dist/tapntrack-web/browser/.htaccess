# TapNTrack SPA — security headers + HTTPS + Angular client-side routing fallback.
# Deploys to the app doc root. If a hand-managed .htaccess already exists on the
# server, reconcile this with it (this file is the version-controlled source).

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS.
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # SPA fallback: anything that isn't a real file/dir is served by index.html
    # (Angular handles the route, incl. the /<tenant>/... path-based tenancy).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), browsing-topics=()"
    # script-src 'self' (no inline/eval) is the key XSS backstop. style-src needs
    # 'unsafe-inline' for Angular component styles + PrimeNG. connect-src allows
    # the API host (+ its /sanctum/csrf-cookie).
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://api.tapntrack.in; worker-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# Never cache the shell so deploys take effect immediately.
<IfModule mod_headers.c>
    <FilesMatch "(index\.html|ngsw\.json|ngsw-worker\.js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
